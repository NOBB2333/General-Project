# 桌面端构建 —— pnpm build:desktop，产物由 Avalonia WebView 加载
#
# VITE_BASE=./：静态资源使用相对路径，因为 WebView 从本地文件系统加载（file://...）
#   若改为 /，资源路径会变成绝对路径，WebView 无法加载
#
# VITE_GLOB_API_URL 直接写后端完整地址（桌面端本机运行，不经过 Nginx）
#   后续可考虑通过客户端配置文件动态注入，无需重新构建
#
VITE_BASE=./

# 桌面端指向本地开发后端，后续可改为客户端配置项
VITE_GLOB_API_URL=https://localhost:44392

VITE_ARCHIVER=false
