# 生产构建 —— pnpm build，构建产物部署到 Linux + Nginx
#
# 前端为纯静态文件，由 Nginx 服务（默认端口 8094）
# VITE_GLOB_API_URL=/api：Axios 发出 /api/app/... 相对路径请求
#   Nginx 必须配置：location /api/ { proxy_pass http://127.0.0.1:5007/api/; }
#   参考配置：General.Web/scripts/deploy/nginx.conf
#
# VITE_BASE=/：静态资源以 / 为根路径，适合 Nginx 直接部署
#   若部署在子路径（例如 /admin/），需将 VITE_BASE 改为 /admin/ 并配置 Nginx 相应 location
#
VITE_BASE=/

# API 走相对路径，由 Nginx 代理到后端（localhost:5007）
VITE_GLOB_API_URL=/api

# 打包后生成 dist.zip
VITE_ARCHIVER=true
