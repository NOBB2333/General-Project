# 端口号
VITE_PORT=5677

VITE_BASE=/

# 接口地址
# 当前先保留模板的 mock 联调方式，后续接入 ABP 时再切为真实接口。
VITE_GLOB_API_URL=/api

# 是否开启 Nitro Mock 服务，true 为开启，false 为关闭
# 开发态保留模板 mock，避免前端在未接真实后端前持续报 /user/info 等接口错误。
VITE_NITRO_MOCK=true

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
