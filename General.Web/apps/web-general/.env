# 应用标题
VITE_APP_TITLE=General Project Management

# 应用命名空间，用于缓存、store等功能的前缀，确保隔离
VITE_APP_NAMESPACE=general-web-general

# 对store进行加密的密钥，在将store持久化到localStorage时会使用该密钥进行加密
VITE_APP_STORE_SECURE_KEY=general-admin-web-general-key

# 当前前端默认承接的平台范围。后续拆独立 APP 时，直接改这里即可。
VITE_GLOB_APP_CODES=platform,project,business
